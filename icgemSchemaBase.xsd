<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://icgem.gfz.de/schema"
           xmlns:grav="http://icgem.gfz.de/schema"
           xmlns:dace="http://datacite.org/schema/kernel-4"
           elementFormDefault="qualified">

  <xs:import namespace="http://datacite.org/schema/kernel-4" 
             schemaLocation="include/includeDatacite/4.7/metadata.xsd"/>

  <xs:include schemaLocation="globalGravityProduct.xsd"/>

  <xs:element name="envelope">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="dace:resource"/>
        
        <xs:element ref="grav:globalGravityProduct"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

</xs:schema>