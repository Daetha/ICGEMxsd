<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           version="1"
           targetNamespace="http://icgem.gfz.de/schema"
           xmlns="http://icgem.gfz.de/schema"
           xmlns:dace="http://datacite.org/schema/kernel-4"
           elementFormDefault="qualified">

  <xs:import namespace="http://datacite.org/schema/kernel-4"
             schemaLocation="../../includeDatacite/4.7/metadata.xsd"/>

  <xs:annotation>
    <xs:documentation>Temporal coverage type for altimetry-derived gravity field models</xs:documentation>
  </xs:annotation>

  <xs:complexType name="altimetryTemporalCoverage">
    <xs:annotation>
      <xs:documentation>
        Time span covered by the satellite altimetry observations used to derive the product.
        Unlike global gravity field models, altimetry-derived products may not have global or full temporal coverage.
        Expressed as a DataCite EDTF date range (e.g. "1992-10-01/2024-12-31").
        Supports open-ended (start/open) and unknown (unknown/end) endpoints.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="temporalCoverage" type="dace:edtf" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>
            Temporal coverage of the altimetry observation period as a DataCite EDTF date range.
            Reuses the DataCite edtf simpleType, consistent with dc:resource/dates in the envelope.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

</xs:schema>
