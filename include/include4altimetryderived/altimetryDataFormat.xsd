<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           version="1"
           targetNamespace="http://icgem.gfz.de/schema"
           xmlns="http://icgem.gfz.de/schema"
           elementFormDefault="qualified">
  <xs:annotation>
    <xs:documentation>Data format type for altimetry-derived gravity field models, restricted to NetCDF</xs:documentation>
  </xs:annotation>

  <xs:simpleType name="altimetryDataFormat">
    <xs:annotation>
      <xs:documentation>
        Altimetry-derived gravity field model products are distributed exclusively in NetCDF format.
      </xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="NetCDF">
        <xs:annotation>
          <xs:documentation>NetCDF (Network Common Data Form) binary format — the only supported release format for altimetry-derived models</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
  </xs:simpleType>

</xs:schema>
